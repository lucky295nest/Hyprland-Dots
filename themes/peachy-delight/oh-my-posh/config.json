{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "peach":    "#F2A07A",
    "rose":     "#F2A7BB",
    "blush":    "#FDE8EC",
    "lavender": "#E8D5FF",
    "sand":     "#FAD4B8",
    "pink":     "#F4B8C8",
    "white":    "#FFF4EE",
    "text":     "#3A1A0A"
  },
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "p:peach",
          "foreground": "p:text",
          "powerline_symbol": "\ue0b4",
          "leading_diamond": "\ue0b6",
          "style": "diamond",
          "template": "{{.Icon}} ",
          "type": "os"
        },
        {
          "background": "p:peach",
          "foreground": "p:text",
          "powerline_symbol": "\ue0b4",
          "style": "diamond",
          "template": "{{ .UserName }}@{{ .HostName }}",
          "type": "session"
        },
        {
          "background": "p:blush",
          "foreground": "p:text",
          "powerline_symbol": "\ue0b4",
          "style": "powerline",
          "template": " {{ .Path }}",
          "properties": {
            "folder_icon": "..\ue5fe..",
            "home_icon": "~",
            "style": "agnoster_short"
          },
          "type": "path"
        },
        {
          "background": "p:rose",
          "foreground": "p:text",
          "powerline_symbol": "\ue0b4",
          "style": "powerline",
          "template": " {{ .HEAD }}",
          "properties": {
            "branch_icon": "\ue725 ",
            "cherry_pick_icon": "\ue29b ",
            "commit_icon": "\uf417 ",
            "fetch_status": false,
            "fetch_upstream_icon": false,
            "merge_icon": "\ue727 ",
            "no_commits_icon": "\uf0c3 ",
            "rebase_icon": "\ue728 ",
            "revert_icon": "\uf0e2 ",
            "tag_icon": "\uf412 "
          },
          "type": "git"
        },
        {
          "background": "p:lavender",
          "foreground": "p:text",
          "powerline_symbol": "\ue0b4",
          "style": "powerline",
          "template": " \ue235 ",
          "properties": {
            "display_mode": "environment"
          },
          "type": "python"
        },
        {
          "background": "p:sand",
          "foreground": "p:text",
          "powerline_symbol": "\ue0b4",
          "style": "powerline",
          "template": "{{ if eq .Code 0 }} \uf05d {{ .Code }} {{ end }}{{ if eq .Code 1 }} \uf52f {{ .Code }} {{ end }}{{ if and (ne .Code 0) (ne .Code 1) }} \uf420 {{ .Code }} {{ end }}",
          "properties": {
            "always_enabled": true
          },
          "type": "exit"
        },
        {
          "background": "p:sand",
          "foreground": "p:text",
          "powerline_symbol": "\ue0b4",
          "trailing_diamond": "\ue0b4",
          "style": "powerline",
          "template": "\uf252 {{ .FormattedMs }} ",
          "properties": {
            "always_enabled": true,
            "threshold": 0,
            "style": "austin"
          },
          "type": "executiontime"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 4
}
