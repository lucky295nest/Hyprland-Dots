{
    "layer": "top",
    "position": "top",
    "height": 42,
    "margin-top": 0,
    "margin-left": 0,
    "margin-right": 0,
    "spacing": 4,

    // ── Layout ────────────────────────────────────────────────────────────
    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [
        "hyprland/window"
    ],
    "modules-right": [
        "tray",
        "pulseaudio",
        "clock"
    ],

    // ── Left ──────────────────────────────────────────────────────────────
    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "sort-by-number": true
    },

    // ── Center ────────────────────────────────────────────────────────────
    "hyprland/window": {
        "format": "{title}",
        "max-length": 60,
        "separate-outputs": true
    },

    // ── Right ─────────────────────────────────────────────────────────────
    "tray": {
        "spacing": 8,
        "icon-size": 16
    },

    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "\ueee8  muted",
        "format-icons": {
            "default": ["\uf027", "\uf028"]
        },
        "on-click": "pavucontrol"
    },

    "clock": {
        "format": " {:%H:%M}",
        "format-alt": " {:%A, %B %d}",
        "tooltip-format": "<tt>{calendar}</tt>"
    }
}
